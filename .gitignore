Manifest.toml
/docs/build/

# per-chapter porting scratch (build scripts, frozen source copies)
_ch*

# Quarto render outputs & cache (notebooks are the source; .html are generated)
*.html
.quarto/
**/*_files/
*.quarto_ipynb

# figures and exported data the example notebooks produce while rendering
# (each notebook creates ./output and writes there; scoped to examples/ so the
# tracked datasets under data/ are unaffected)
/examples/**/output/

*.jl.cov
*.jl.*.cov
*.jl.mem
.DS_Store

# downloaded dataset cache (ch02 fetches from stata-press)
census.dta
